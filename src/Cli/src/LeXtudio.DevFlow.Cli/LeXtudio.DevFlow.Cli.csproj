<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>LeXtudio.DevFlow.Cli</RootNamespace>
    <PackageId>LeXtudio.DevFlow.Cli</PackageId>
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>wpflex</ToolCommandName>
    <Description>CLI and global tool for LeXtudio WPF DevFlow workflows.</Description>
    <PackageTags>wpf;devflow;cli;tool;automation</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../../../../src/DevFlow/LeXtudio.DevFlow.Driver/LeXtudio.DevFlow.Driver.csproj" />
  </ItemGroup>
</Project>
